{
  "ollama_model": "llama3.2:latest",
  "strict_engagement_validation": false,
  "max_radar_charts": 4,
  "ui": {
    "app_title": "Family Reflection Map",
    "intro_title": "A shared space for reflection",
    "intro_text": "This experience helps family members reflect on misunderstandings linked to communication and generational perspectives.",
    "intro_button": "Start",
    "privacy_title": "Privacy and participation",
    "privacy_text": "Each participant responds independently. Inputs are personal perspectives and are not treated as objective truth. Responses are stored in structured form for comparison.",
    "privacy_agree": "I agree",
    "privacy_decline": "I do not agree",
    "privacy_decline_message": "The interaction has ended because consent was not provided.",
    "profile_title": "Participant profile",
    "questions_title": "Reflective questions",
    "submit_participant": "Save participant",
    "add_member": "Add another member",
    "we_are_ready": "We are ready",
    "member_saved": "Participant saved independently.",
    "ready_title": "Collection checkpoint",
    "ready_text": "You can add another participant or continue to analysis.",
    "analysis_title": "Relational map output",
    "shared_patterns_title": "Shared patterns",
    "gaps_title": "Differences in intensity",
    "external_title": "Comparison with previous family groups",
    "feedback_title": "Final reflection",
    "feedback_question": "Did this help you reflect?",
    "feedback_placeholder": "Optional note",
    "feedback_submit": "Save feedback",
    "restart": "Start over",
    "loading": "Processing...",
    "max_charts_note": "Only the first {max_radar_charts} radar charts are displayed.",
    "messages": {
      "network_error": "Request failed. Please try again.",
      "participant_validation_error": "Please complete all profile fields and all three answers.",
      "disengaged_input": "Your input seems unrelated or not sufficiently engaged with the reflective questions. Please continue only if you are willing to engage meaningfully. AI processing consumes energy.",
      "no_participants": "Add at least one participant before analysis.",
      "feedback_saved": "Feedback saved.",
      "session_reset": "Session restarted."
    },
    "labels": {
      "role": "Role (parent/child)",
      "generation": "Generation",
      "family_role": "Family role"
    }
  },
  "profile_options": {
    "role": [
      {"label": "Parent", "value": "Parent"},
      {"label": "Child", "value": "Child"}
    ],
    "generation": [
      {"label": "Generation Z (approximately 1997–2012)", "value": "Generation Z (approximately 1997–2012)"},
      {"label": "Millennials (approximately 1981–1996)", "value": "Millennials (approximately 1981–1996)"},
      {"label": "Generation X (approximately 1965–1980)", "value": "Generation X (approximately 1965–1980)"},
      {"label": "Baby Boomers (approximately 1946–1964)", "value": "Baby Boomers (approximately 1946–1964)"},
      {"label": "Other", "value": "Other"}
    ],
    "family_role": [
      {"label": "Mother", "value": "Mother"},
      {"label": "Father", "value": "Father"},
      {"label": "Older daughter", "value": "Older daughter"},
      {"label": "Younger son", "value": "Younger son"},
      {"label": "Grandmother", "value": "Grandmother"},
      {"label": "Grandfather", "value": "Grandfather"},
      {"label": "Other", "value": "Other"}
    ]
  },
  "questions": {
    "misunderstood": "When did you recently feel misunderstood in your family, and what do you think happened?",
    "missing": "What do you feel is missing in your family communication right now?",
    "wish": "What do you wish others in your family could better understand about your perspective?"
  },
  "prompts": {
    "engagement_system_prompt": "You are a strict validation assistant. Stay neutral and evaluate relevance and engagement only.",
    "engagement_check_prompt": "Evaluate whether the participant answers are relevant to the three reflective family questions and show meaningful engagement. Return only valid JSON with keys: is_relevant (boolean), is_engaged (boolean), reason (string). Participant metadata: role={role}, generation={generation}, family_role={family_role}. Questions: misunderstood={question_misunderstood}; missing={question_missing}; wish={question_wish}. Answers JSON: {answers_json}.",
    "analysis_system_prompt": "You are a neutral reflection mapper. Do not assign blame, advice, or judgment.",
    "analysis_prompt": "Map the participant text into the provided categories and return only valid JSON. Scale each category score from 0 to 10. Keep all keys exactly as provided. Also include extracted keywords (list of strings) and sentiment (number between -1 and 1). Participant metadata: role={role}, generation={generation}, family_role={family_role}. Questions: misunderstood={question_misunderstood}; missing={question_missing}; wish={question_wish}. Answers JSON: {answers_json}. Use these category templates exactly. Basic emotions template: {basic_emotions_template}. Derived emotions template: {derived_emotions_template}. Mental states template: {mental_states_template}. Relational needs template: {relational_needs_template}. Output schema: {\"basic_emotions\": {...}, \"derived_emotions\": {...}, \"mental_states\": {...}, \"relational_needs\": {...}, \"keywords\": [], \"sentiment\": 0.0}",
    "external_comparison_prompt": "Summarize the comparison between current family aggregate scores and historical aggregate scores in a neutral way. Return only valid JSON with keys: alignment (array of strings), divergence (array of strings), note (string). Current aggregate: {current_aggregate_json}. Historical aggregate: {historical_aggregate_json}."
  },
  "response_schemas": {
    "engagement": {
      "type": "object",
      "properties": {
        "is_relevant": {"type": "boolean"},
        "is_engaged": {"type": "boolean"},
        "reason": {"type": "string"}
      },
      "required": ["is_relevant", "is_engaged", "reason"],
      "additionalProperties": false
    },
    "analysis": {
      "type": "object",
      "properties": {
        "basic_emotions": {
          "type": "object",
          "properties": {
            "Joy": {"type": "number"},
            "Sadness": {"type": "number"},
            "Anger": {"type": "number"},
            "Fear": {"type": "number"},
            "Disgust": {"type": "number"},
            "Surprise": {"type": "number"}
          },
          "required": ["Joy", "Sadness", "Anger", "Fear", "Disgust", "Surprise"],
          "additionalProperties": false
        },
        "derived_emotions": {
          "type": "object",
          "properties": {
            "Enthusiasm": {"type": "number"},
            "Gratitude": {"type": "number"},
            "Pride": {"type": "number"},
            "Love": {"type": "number"},
            "Satisfaction": {"type": "number"},
            "Relief": {"type": "number"},
            "Affliction": {"type": "number"},
            "Loneliness": {"type": "number"},
            "Despair": {"type": "number"},
            "Disappointment": {"type": "number"},
            "Nostalgia": {"type": "number"},
            "Frustration": {"type": "number"},
            "Impatience": {"type": "number"},
            "Resentment": {"type": "number"},
            "Anxiety": {"type": "number"},
            "Insecurity": {"type": "number"},
            "Stress": {"type": "number"},
            "Panic": {"type": "number"},
            "Worry": {"type": "number"},
            "Shame": {"type": "number"},
            "Guilt": {"type": "number"},
            "Jealousy": {"type": "number"},
            "Envy": {"type": "number"},
            "Helplessness": {"type": "number"}
          },
          "required": ["Enthusiasm", "Gratitude", "Pride", "Love", "Satisfaction", "Relief", "Affliction", "Loneliness", "Despair", "Disappointment", "Nostalgia", "Frustration", "Impatience", "Resentment", "Anxiety", "Insecurity", "Stress", "Panic", "Worry", "Shame", "Guilt", "Jealousy", "Envy", "Helplessness"],
          "additionalProperties": false
        },
        "mental_states": {
          "type": "object",
          "properties": {
            "Overthinking": {"type": "number"},
            "Confusion": {"type": "number"},
            "Apathy": {"type": "number"},
            "Boredom": {"type": "number"},
            "Mental fatigue": {"type": "number"},
            "Indifference": {"type": "number"},
            "Disinterest": {"type": "number"},
            "Uncertainty": {"type": "number"},
            "Dissociation / detachment": {"type": "number"},
            "Feeling overwhelmed": {"type": "number"}
          },
          "required": ["Overthinking", "Confusion", "Apathy", "Boredom", "Mental fatigue", "Indifference", "Disinterest", "Uncertainty", "Dissociation / detachment", "Feeling overwhelmed"],
          "additionalProperties": false
        },
        "relational_needs": {
          "type": "object",
          "properties": {
            "Feeling heard": {"type": "number"},
            "Feeling understood": {"type": "number"},
            "Feeling accepted": {"type": "number"},
            "Feeling valued": {"type": "number"},
            "Feeling safe": {"type": "number"},
            "Feeling free to be yourself": {"type": "number"},
            "Empathy": {"type": "number"},
            "Connection": {"type": "number"},
            "Authentic dialogue": {"type": "number"},
            "Belonging": {"type": "number"}
          },
          "required": ["Feeling heard", "Feeling understood", "Feeling accepted", "Feeling valued", "Feeling safe", "Feeling free to be yourself", "Empathy", "Connection", "Authentic dialogue", "Belonging"],
          "additionalProperties": false
        },
        "keywords": {
          "type": "array",
          "items": {"type": "string"}
        },
        "sentiment": {"type": "number"}
      },
      "required": ["basic_emotions", "derived_emotions", "mental_states", "relational_needs", "keywords", "sentiment"],
      "additionalProperties": false
    },
    "external_comparison": {
      "type": "object",
      "properties": {
        "alignment": {
          "type": "array",
          "items": {"type": "string"}
        },
        "divergence": {
          "type": "array",
          "items": {"type": "string"}
        },
        "note": {"type": "string"}
      },
      "required": ["alignment", "divergence", "note"],
      "additionalProperties": false
    }
  },
